<%- include('../partials/head') %>
  </head>

  <body>
    <%- include('../partials/nav') %>
      <main class="pb-20">
        <h1 class="text-2xl text-center mt-5">You are in Home detail Page</h1>
        <ul class="mt-6 md:ml-88 grid grid-cols-1 md:grid-cols-1 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
          <li
            class="bg-white rounded-lg self-center shadow-md hover:shadow-lg overflow-hidden transform cursor-pointer border-t-2  border-cyan-600 my-0 mx-auto w-[90%] md:w-[150%] py-4 px-5">
            <div class="relative h-40 overflow-hidden bg-gray-200">
              <img src="/<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover">
            </div>
            <div class="p-4">
              <h2 class="text-base font-semibold text-gray-900">
                <%= home.houseName %>
              </h2>
              <p class="text-gray-500 text-xs mt-1">📍 <%= home.location %>
              </p>
              <div class="flex justify-between items-center mt-2 pt-3 border-t border-gray-100">
                <span class="text-lg font-bold text-cyan-600">Rs. <%= home.price %></span>
                <span class="flex items-center gap-1 bg-amber-50 text-amber-700 px-2 py-1 rounded text-xs font-medium">⭐
                  <%= home.rating %></span>
              </div>
                <p style="font-style: italic;" class="text-gray-600 text-sm mt-4">
                  <%= home.description %>
                </p>
            </div>
            <%- include('../partials/favorite', {home: home})%>
          </li>
        </ul>
      </main>
  </body>

  </html>