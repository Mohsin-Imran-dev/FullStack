<%- include('../partials/head') %>
  </head>

  <body class="flex flex-col">
    <%- include('../partials/nav') %>
      <main class="pb-20">
        <h1 class="text-2xl text-center mt-5">Here are our Indexed List:</h1>
        <ul class="mt-6 grid grid-cols-1 md:grid-cols-4 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
          <% registeredHome.forEach((home)=> { %>
            <li
              class="bg-white rounded-lg shadow-md hover:shadow-lg overflow-hidden transform cursor-pointer border-t-2 border-cyan-600 mx-auto my-0 w-[90%] md:w-full">
              <div class="relative h-40 overflow-hidden bg-gray-200">
                <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover">
              </div>
              <div class="p-4">
                <h2 class="text-base font-semibold text-gray-900">
                  <%= home.houseName %>
                </h2>
                <p class="text-gray-500 text-xs mt-1">📍 <%= home.location %>
                </p>
                <a href="/rules/<%= home._id %>" class="text-red-700 text-sm block mt-2">Download the rules</a>
                <div class="flex justify-between items-center mt-1 pt-3 border-t border-gray-100">
                  <span class="text-lg font-bold text-cyan-600">Rs. <%= home.price %></span>
                  <span
                    class="flex items-center gap-1 bg-amber-50 text-amber-700 px-2 py-1 rounded text-xs font-medium">⭐
                    <%= home.rating %>
                  </span>
                </div>

                <!-- Button ki jagah ye condition laga do -->
                <% if (!isLoggedIn) { %>
                  <a href="/login"
                    class="block w-full bg-cyan-600 hover:bg-cyan-700 text-white font-semibold mt-5 py-2 rounded-lg text-center transition-all duration-200">
                    <i class="fas fa-sign-in-alt mr-2"></i>Login to Book
                  </a>
                  <% } else if (bookedHomeIds.includes(home._id.toString())) { %>
                    <div
                      class="block w-full bg-green-600 text-white font-semibold mt-5 py-2 rounded-lg text-center cursor-default">
                      <i class="fas fa-check-circle mr-2"></i>Already Booked
                    </div>
                    <% } else { %>
                      <a href="/confirm-booking/<%= home._id %>"
                        class="block w-full bg-cyan-600 hover:bg-cyan-700 text-white font-semibold mt-5 py-2 rounded-lg text-center transition-all duration-200">
                        <i class="fas fa-calendar-check mr-2"></i>Book Now
                      </a>
                      <% } %>
              </div>
            </li>
            <% }); %>
        </ul>
      </main>
  </body>

  </html>